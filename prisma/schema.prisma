datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Content {
  // SQLite ne supporte pas les enum Prisma : `type` est une string contrainte
  // côté TS/zod (TEXT | RICHTEXT | JSON | IMAGE_REF).
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("TEXT")
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id           String   @id @default(cuid())
  key          String?  @unique
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())
}

model SimulatorStep {
  // `fieldType` contraint côté TS/zod (RADIO | CHECKBOX | NUMBER | TEXT |
  // EMAIL | TEL | SELECT | TEXTAREA), stocké en string car SQLite n'a pas d'enum.
  // Le `label` peut contenir un fragment markdown `**...**` surligné côté rendu.
  id              String   @id @default(cuid())
  order           Int      @unique
  key             String   @unique
  label           String
  helpText        String?
  fieldType       String
  required        Boolean  @default(true)
  options         String?
  config          String?
  // Extensions phase 4 (dynamisation simulateur)
  illustrationKey String?  // Illustration globale de l'étape (si pas par option)
  encouragement   String?  // Message d'encouragement affiché sous le titre
  helpTooltip     String?  // Texte du tooltip (i)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Témoignages éditables, affichés dans le simulateur via TestimonialFlash
/// et utilisables ailleurs sur le site. Filtrables par `context` (ex. "PAC").
model Testimonial {
  id         String   @id @default(cuid())
  quote      String
  authorName String
  authorCity String
  rating     Int      @default(5)
  context    String?
  active     Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active, order])
}

model Quote {
  id         String   @id @default(cuid())
  answers    String
  firstName  String?
  lastName   String?
  email      String?
  phone      String?
  postalCode String?
  city       String?
  emailSent  Boolean  @default(false)
  emailError String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  message    String
  emailSent  Boolean  @default(false)
  emailError String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}

/// Conversation chatbox abandonnée ou complétée. `completed=true` quand
/// l'utilisateur a cliqué sur "Voir mes aides" pour passer au simulateur.
/// Si `convertedToQuoteId` est posé, la conversion a été suivie d'une vraie
/// soumission du simulateur (rapprochement par clé `chatbox.leadId` en
/// sessionStorage côté client lors du submit du Quote).
model ChatLead {
  id                 String   @id @default(cuid())
  answers            String   // JSON {step1, step2, step3, step4}
  postalCode         String?
  city               String?
  completed          Boolean  @default(false)
  convertedToQuoteId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([createdAt])
  @@index([completed])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  email     String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}
