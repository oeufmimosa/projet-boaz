datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Content {
  // SQLite ne supporte pas les enum Prisma : `type` est une string contrainte
  // côté TS/zod (TEXT | RICHTEXT | JSON | IMAGE_REF).
  // Workflow draft → publication : `draftValue` contient la prochaine valeur
  // en attente. `value` est ce qui est servi au public. Au publish, draft → value.
  id             String    @id @default(cuid())
  key            String    @unique
  value          String
  type           String    @default("TEXT")
  draftValue     String?
  draftUpdatedAt DateTime?
  draftUpdatedBy String?
  publishedAt    DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model MediaAsset {
  // Mêmes principes draft/publish que Content. Les champs `draft*` portent
  // l'image en attente de publication ; `url` est servi au public.
  // Variantes responsive générées par sharp et stockées en JSON dans `variants`.
  id              String    @id @default(cuid())
  key             String?   @unique
  filename        String
  originalName    String
  mimeType        String
  size            Int
  url             String
  width           Int?
  height          Int?
  blurDataURL     String?
  variants        String?   // JSON {"webp": {"1x":"...","2x":"...","0.5x":"..."}}
  // Draft pendant
  draftFilename   String?
  draftUrl        String?
  draftWidth      Int?
  draftHeight     Int?
  draftBlurDataURL String?
  draftVariants   String?
  draftUpdatedAt  DateTime?
  draftUpdatedBy  String?
  // Attribution stock — null si l'image vient d'un upload local
  attribution     String?   // ex. "Photo de John Doe sur Unsplash"
  attributionUrl  String?   // lien vers la page source de l'image
  licenseType     String?   // ex. "Unsplash License", "Pexels License"
  createdAt       DateTime  @default(now())
  inlineUsages    ArticleInlineImage[]
}

/// Images insérées entre les sections H2 d'un article (markdown du blog).
/// Le contenu de l'article référence les images via tokens `{{img:1}}`,
/// `{{img:2}}` etc. — le `<MarkdownRenderer>` les remplace au rendu par
/// une `<figure>` complète avec figcaption + attribution.
model ArticleInlineImage {
  id               String     @id @default(cuid())
  articleId        String
  article          Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  mediaAssetId     String
  mediaAsset       MediaAsset @relation(fields: [mediaAssetId], references: [id])
  position         Int        // ordre d'apparition dans l'article (1, 2, 3…)
  caption          String?    // légende éditoriale (différente de l'attribution stock)
  placeholderToken String     // token markdown ex. "{{img:1}}" remplacé au rendu
  createdAt        DateTime   @default(now())

  @@unique([articleId, position])
  @@index([articleId])
}

/// Journal d'audit des modifications de contenu (draft/publish/discard/upload).
/// Lecture seule, paginée dans /admin/audit (à venir).
model AuditLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String   // 'draft_set' | 'publish' | 'discard' | 'upload' | 'delete'
  key        String?
  before     String?
  after      String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([adminEmail])
}

model SimulatorStep {
  // `fieldType` contraint côté TS/zod (RADIO | CHECKBOX | NUMBER | TEXT |
  // EMAIL | TEL | SELECT | TEXTAREA), stocké en string car SQLite n'a pas d'enum.
  // Le `label` peut contenir un fragment markdown `**...**` surligné côté rendu.
  id              String   @id @default(cuid())
  order           Int      @unique
  key             String   @unique
  label           String
  helpText        String?
  fieldType       String
  required        Boolean  @default(true)
  options         String?
  config          String?
  // Extensions phase 4 (dynamisation simulateur)
  illustrationKey String?  // Illustration globale de l'étape (si pas par option)
  encouragement   String?  // Message d'encouragement affiché sous le titre
  helpTooltip     String?  // Texte du tooltip (i)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Témoignages éditables, affichés dans le simulateur via TestimonialFlash
/// et utilisables ailleurs sur le site. Filtrables par `context` (ex. "PAC").
model Testimonial {
  id         String   @id @default(cuid())
  quote      String
  authorName String
  authorCity String
  rating     Int      @default(5)
  context    String?
  active     Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active, order])
}

model Quote {
  id         String   @id @default(cuid())
  answers    String
  firstName  String?
  lastName   String?
  email      String?
  phone      String?
  postalCode String?
  city       String?
  emailSent  Boolean  @default(false)
  emailError String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  message    String
  emailSent  Boolean  @default(false)
  emailError String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  inlineImages ArticleInlineImage[]

  @@index([published, publishedAt])
}

/// Conversation chatbox abandonnée ou complétée. `completed=true` quand
/// l'utilisateur a cliqué sur "Voir mes aides" pour passer au simulateur.
/// Si `convertedToQuoteId` est posé, la conversion a été suivie d'une vraie
/// soumission du simulateur (rapprochement par clé `chatbox.leadId` en
/// sessionStorage côté client lors du submit du Quote).
model ChatLead {
  id                 String   @id @default(cuid())
  answers            String   // JSON {step1, step2, step3, step4}
  postalCode         String?
  city               String?
  completed          Boolean  @default(false)
  convertedToQuoteId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([createdAt])
  @@index([completed])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  email     String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

/// Soumissions du formulaire de parrainage (page /parrainage).
/// `status` est contraint côté TS/zod : PENDING | CONTACTED | ELIGIBLE |
/// CONVERTED | PAID | REJECTED. Stocké en string car SQLite n'a pas d'enum.
/// Workflow admin manuel (changement de statut, ajout de notes, marquage prime).
model Referral {
  id                String    @id @default(cuid())

  // Parrain
  sponsorTitle      String?
  sponsorLastName   String
  sponsorFirstName  String
  sponsorEmail      String
  sponsorPhone      String?

  // Filleul
  refereeFirstName  String
  refereeLastName   String
  refereeEmail      String?
  refereePhone      String?
  refereePostalCode String
  projectType       String    // slug du service ou 'autre'
  message           String?

  // Consentement et tracking
  consentGiven      Boolean
  consentTimestamp  DateTime
  ipAddress         String?

  // Statut et workflow
  status            String    @default("PENDING")
  rewardAmount      Int?      // en euros TTC, défaut 250
  rewardPaidAt      DateTime?
  internalNotes     String?

  // Emails
  adminEmailSent    Boolean   @default(false)
  sponsorEmailSent  Boolean   @default(false)
  refereeEmailSent  Boolean   @default(false)
  emailErrors       String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([sponsorEmail])
  @@index([refereeEmail])
}
