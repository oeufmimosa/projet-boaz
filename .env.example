# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Auth ---
# Random 32+ char string used to derive HMAC for session token storage
AUTH_SECRET="change-me-to-a-long-random-string-please-32chars-min"
# Session lifetime in days
SESSION_TTL_DAYS=7
# Default admin (used by seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe!2026"

# --- Rate limiting ---
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# --- Uploads ---
UPLOAD_MAX_BYTES=5242880   # 5 MB
UPLOAD_DIR="public/uploads"
PUBLIC_UPLOAD_PREFIX="/uploads"

# --- Mailer (SMTP). If SMTP_HOST is empty in dev, Ethereal is used. ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Projet Boaz <no-reply@example.com>"
ADMIN_NOTIFICATION_EMAIL="admin@example.com"

# --- App ---
NEXT_PUBLIC_SITE_NAME="Projet Boaz"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="info"
